# Copy to .env.deploy and fill in real values before deploying:
#   cp .env.deploy.example .env.deploy
#   docker compose --env-file .env.deploy up -d --build
#
# Keep .env.deploy out of version control (already covered by .gitignore).

# ── Database ───────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=aistudio

# ── API secrets (REQUIRED) ─────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
# 32-byte AES-256-GCM key. Generate: openssl rand -hex 32
FIELD_ENCRYPTION_KEY=

# ── API tuning (optional) ──────────────────────────────────────
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30
ORCHESTRATION_RECONCILE_ENABLED=false
MULTICA_API_URL=
MULTICA_API_TOKEN=

# ── Networking ─────────────────────────────────────────────────
# Host ports published by docker compose.
API_PORT=4000
WEB_PORT=8080

# Browser-facing API URL. Baked into the web bundle at build time, so it must be
# reachable from the user's browser (a public hostname behind your reverse proxy,
# or http://localhost:4000 for a local single-host trial).
PUBLIC_API_URL=http://localhost:4000

# CORS allowlist for the API. Must include the origin the web app is served from.
# k3s NodePort web: http://127.0.0.1:30080
# docker compose web: http://localhost:8080
CORS_ORIGINS=http://127.0.0.1:30080
